<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Moamalat Payment Provider -->
    <record id="payment_provider_moamalat" model="payment.provider">
        <field name="name">Moamalat</field>
        <field name="code">moamalat</field>
        <field name="image_128" type="base64" file="payment_moamalat/static/description/icon.png"/>
        <field name="inline_form_view_id" ref="inline_form"/>
        <field name="allow_tokenization">False</field>
        <field name="allow_express_checkout">False</field>
        <field name="state">disabled</field>
        <!-- Use the existing card payment method from the core payment module -->
        <field name="payment_method_ids"
               eval="[Command.set([
                         ref('payment.payment_method_card'),
                     ])]"
        />
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Load the Moamalat Lightbox SDK on pages with the payment form -->
    <template id="payment_moamalat.form" inherit_id="payment.form">
        <xpath expr="." position="inside">
            <!-- Lightbox script will be loaded dynamically based on provider state -->
            <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/3.1.9-1/crypto-js.min.js"/>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/3.1.9-1/hmac-sha256.min.js"/>
        </xpath>
    </template>

    <!-- Inline form template for Moamalat payment method -->
    <template id="inline_form">
        <t t-set="inline_form_values"
           t-value="provider_sudo._moamalat_get_inline_form_values(
                        amount,
                        currency,
                        partner_id,
                    )"
        />
        <div name="o_moamalat_element_container"
             class="o_moamalat_form"
             t-att-data-moamalat-inline-form-values="inline_form_values"
        >
            <!-- Container for Lightbox initialization messages -->
            <div id="o_moamalat_loading" class="text-center py-3" style="display: none;">
                <i class="fa fa-spinner fa-spin fa-2x"/>
                <p class="mt-2 mb-0">Preparing secure payment...</p>
            </div>
            <div id="o_moamalat_error" class="alert alert-danger" style="display: none;">
                <i class="fa fa-exclamation-triangle"/>
                <span id="o_moamalat_error_message">An error occurred.</span>
            </div>
        </div>
    </template>

</odoo>
